# Variables de entorno para desarrollo local
# Copia este archivo como ".env" y rellena tus valores
# NUNCA subas el archivo ".env" a GitHub (ya está en .gitignore)

TRAKT_CLIENT_ID=pon_aqui_tu_client_id_de_trakt
TRAKT_USERNAME=tu_usuario_en_trakt
LETTERBOXD_USER=tu_usuario_en_letterboxd
LETTERBOXD_PASS=tu_contraseña_de_letterboxd

# Modo "cuasi tiempo real": ventana de horas que mira hacia atrás
# (2h = si falla una ejecucion, la siguiente recoge lo perdido)
HOURS_WINDOW=2

# Incluir series además de películas en el scan de Trakt
# (Letterboxd solo importa peliculas; las series se loguean pero no se suben)
SYNC_SHOWS=true

# false = ver el Chrome abrirse (ideal para debug local)
HEADLESS=false
